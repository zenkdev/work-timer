{
  "name": "work-timer",
  "version": "1.0.3",
  "description": "Chrome Extension, TypeScript, Visual Studio Code",
  "scripts": {
    "watch": "vite build --mode development --watch",
    "build": "tsgo -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest --ui",
    "format": "prettier --write .",
    "lint": "eslint .",
    "version": "node scripts/sync-version.js && git add public/manifest.json",
    "prepare": "husky"
  },
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zenkdev/work-timer.git"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "json-2-csv": "^5.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.39.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/babel__core": "7.20.5",
    "@types/chrome": "^0.1.40",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260414.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/ui": "4.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "8.0.8",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": "eslint --cache --fix",
    "*.{js,ts,jsx,tsx,css,md}": "prettier --write"
  }
}
